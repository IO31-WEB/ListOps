# ============================================================
# CampaignAI Environment Variables
# Copy this to .env.local and fill in all values
# ============================================================

# ── Clerk Authentication ─────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Database (Neon PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/campaignai?sslmode=require

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Stripe Billing ────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxxx
STRIPE_STARTER_YEARLY_PRICE_ID=price_xxxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxx
STRIPE_BROKERAGE_MONTHLY_PRICE_ID=price_xxxx
STRIPE_BROKERAGE_YEARLY_PRICE_ID=price_xxxx

# ── SimplyRETS (MLS Data) ─────────────────────────────────────
SIMPLYRETS_API_KEY=xxxx
SIMPLYRETS_API_SECRET=xxxx

# ── Cloudflare R2 (File Storage) ─────────────────────────────
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=campaignai-assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.campaignai.io

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=hello@listops.io

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://listops.io
NEXT_PUBLIC_APP_NAME=ListOps

# ── Upstash Redis (Rate Limiting & Caching) ───────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ── PostHog (Analytics) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
